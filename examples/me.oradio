# me.oradio — the flagship concept station. It has NO pre-built world: "me" emerges from the
# telemetry I choose to feed it. The visual organism mutates according to me; the narration is me;
# the transient surfaces are about me. On someone else's machine it's THEIR telemetry, their "me".
#
# This is a DEFAULT/example. The point isn't this file — it's that you open it, go "mine's better
# with THESE endpoints," and rebuild it locally, privately, forever. Nothing is networked.
#
# Every telemetry line below is SENSITIVE: the Club advertises exactly what it would read and will
# NOT touch any of it without your explicit, remembered consent. Deny one and the station still
# runs — just without that feed.
oradio: me
telemetry:
  - { source: pc_telemetry, name: pc }            # your PC activity + resource metrics
  - { source: ring_telemetry, name: ring }        # your COLMI R02: heart rate, motion, sleep
lens: identity
surfaces: [ribbon, voice]
club: [llm, voices]
