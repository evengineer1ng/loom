# A .loom — the whole format. Two fields. It GENERATES one .oradio (1:1).
# Run it:  python -c "from loom.dotloom import load_loom_file; from oradio_engine.loader import open_oradio; open_oradio(load_loom_file('spec/examples/quiet-house.loom')).engine.run(8)"
universe: a quiet house that notices me
connections:
  - { plugin: simulated_spatial_array, name: array, nodes: [front_door, living_room, kitchen] }
