# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Test / tooling
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/

# Envs
.venv/
venv/
env/

# Editors / OS
.vscode/
.idea/
*.swp
Thumbs.db
Desktop.ini

# Endpoint state — the Club lives on the machine, never in the repo.
# (default dir is ~/.oradio_club; ignore any local copy if one lands here)
.oradio_club/

# Regenerable caches & outputs (tapes/grammars under data/ ARE tracked; these are not)
data/f1_cache/
data/loomspeech/
# exports/ holds regenerable mints EXCEPT the genesis kernel.oradio, which is a tracked artifact
# (it was lost once because this whole dir was ignored — never again).
exports/*
!exports/kernel.oradio
transcripts/
*.spec.bak

# Club = baked/cached relationship media (crossovers, doors, pts, loop/thumb caches). Machine-side,
# regenerable from the oradios + engine; never in the repo.
club/

# Runtime state written by the running shell/station (not source)
*.sqlite
*.sqlite-shm
*.sqlite-wal
# ...but a BRICK package is named `storage.sqlite` — don't let the DB rule eat its source
# (keep the .py/.md; still ignore its compiled __pycache__).
!**/storage.sqlite/
!**/storage.sqlite/*.py
!**/storage.sqlite/*.md
station_memory.json
status.json
.active_loom.json
.switch_request

# NCM bridge runtime files (written by the relay / game)
integrations/ncm/bridge/
